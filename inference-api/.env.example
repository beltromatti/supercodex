# ----------------------------
# Auth (do NOT commit real tokens)
# ----------------------------
HUGGING_FACE_HUB_TOKEN=hf_xxx

# Optional alias (your entrypoint already copies HF_TOKEN -> HUGGING_FACE_HUB_TOKEN if set)
# HF_TOKEN=hf_xxx

# ----------------------------
# Public URL hint (optional)
# Used only to PRINT a client-ready /v1 URL at startup.
# On Vast.ai, external ports are often assigned dynamically, so you may leave this empty.
# ----------------------------
PUBLIC_BASE_URL=

# ----------------------------
# vLLM tuning overrides (optional)
# ----------------------------
# Safe Vast boot profile for 32 GB cards. Scale up later if stable.
MAX_MODEL_LEN=49152
GPU_MEMORY_UTILIZATION=0.95
KV_CACHE_DTYPE=auto
ENABLE_KV_DTYPE_FALLBACK=0
MAX_NUM_SEQS=1
SWAP_SPACE_GB=24
# Preferred vLLM format is JSON object string.
# Legacy format image=1,video=0 is still accepted by start-vllm.sh.
LIMIT_MM_PER_PROMPT={"image":1,"video":0}
# Disable multimodal preprocessor cache (RAM) to reduce instability on tight setups.
MM_PROCESSOR_CACHE_GB=0
# Skip multimodal profiling at startup to avoid large temporary allocations.
SKIP_MM_PROFILING=1
# Safety: if LIMIT_MM_PER_PROMPT misses keys, enforce defaults below.
ENFORCE_MM_DEFAULT_LIMITS=1
MM_DEFAULT_IMAGE_LIMIT=1
MM_DEFAULT_VIDEO_LIMIT=0
ENABLE_LOG_REQUESTS=0
